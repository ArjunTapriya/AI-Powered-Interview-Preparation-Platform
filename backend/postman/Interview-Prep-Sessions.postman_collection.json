{
  "info": {
    "name": "Interview Prep Platform API — Sessions",
    "_postman_id": "c3d4e5f6-a7b8-9012-cdef-123456789012",
    "description": "Interview Sessions module endpoints for the AI-Powered Interview Preparation Platform.\n\nBase URL: `http://localhost:4000/api`\n\nAll responses use:\n```json\n{ \"success\": true, \"message\": \"\", \"data\": {} }\n```",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:4000/api"
    },
    {
      "key": "accessToken",
      "value": ""
    },
    {
      "key": "sessionId",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Interview Sessions",
      "item": [
        {
          "name": "Create Session",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const json = pm.response.json();",
                  "  pm.collectionVariables.set('sessionId', json.data.session.id);",
                  "  pm.test('POST /interviews — success', () => pm.expect(json.success).to.be.true);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }]
            },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"type\": \"DSA\",\n  \"company\": \"Google\",\n  \"overallScore\": 82,\n  \"durationMin\": 45,\n  \"codeSnippet\": \"function mergeKLists(lists: ListNode[]): ListNode | null {\\n    // Optimal solution\\n}\",\n  \"metrics\": {\n    \"correctness\": 80,\n    \"speed\": 75,\n    \"architecture\": 90,\n    \"communication\": 85\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/interviews",
              "host": ["{{baseUrl}}"],
              "path": ["interviews"]
            },
            "description": "Create a new interview session."
          },
          "response": []
        },
        {
          "name": "Get All Sessions",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/interviews?page=1&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["interviews"],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "10"
                }
              ]
            },
            "description": "Returns all interview sessions for the authenticated user, paginated."
          },
          "response": []
        },
        {
          "name": "Get Session By ID",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/interviews/{{sessionId}}",
              "host": ["{{baseUrl}}"],
              "path": ["interviews", "{{sessionId}}"]
            },
            "description": "Returns a specific interview session."
          },
          "response": []
        },
        {
          "name": "Delete Session",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }]
            },
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/interviews/{{sessionId}}",
              "host": ["{{baseUrl}}"],
              "path": ["interviews", "{{sessionId}}"]
            },
            "description": "Deletes a specific interview session."
          },
          "response": []
        }
      ]
    }
  ]
}
